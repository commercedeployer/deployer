# Container deploy admin — single user, all settings via env.
# Copy to .env and set values.

# Mode: production on server; development only for local HTTP without HTTPS.
NODE_ENV=production

# Login and password (single user). Password is hashed; hash created from ADMIN_PASSWORD on first run.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password

# App secret (UI session cookie + MCP key HMAC). Generate: openssl rand -hex 32
DEPLOYER_SECRET=replace-with-random-32-char-string

# Public HTTPS URL (MCP hints, Cursor config). Empty = from browser request (Host + proxy).
# On VPS stack: https://deployer.example.com
# DEPLOYER_PUBLIC_BASE_URL=https://deployer.example.com

# App port (inside container)
PORT=3000

# Docker socket path (default /var/run/docker.sock).
# DOCKER_HOST=unix:///var/run/docker.sock

# Host base directory for container data. With removeData=true only paths under this dir are deleted.
DEPLOY_BASE_PATH=/opt/deploy-data

# Provision/deprovision tools installed inside THIS container on start (Alpine apk).
# node is always present (base image) — not listed here.
# Comma or semicolon list; empty = bash,curl
# Keys: bash, psql, mysql, mariadb, mongosh, curl, jq, python3, openssl, rsync,
#       openssh, bind, zip (+ aliases postgres, mongo, ssh, dig)
# Example for Postgres tenant templates (umami-pg): bash,curl,psql
# DEPLOYER_SOFTWARE=bash,curl,psql

# Templates directory inside deployer container.
# TEMPLATES_DIR=/app/templates

# Image pull policy on deploy:
# always       - check registry and pull (default)
# ifNotPresent - pull only if missing locally
DEFAULT_PULL_POLICY=always
PULL_MAX_ATTEMPTS=3

# CORS allowed origin (e.g. https://pay.example.com). Unset = no cross-origin browser API (safe default).
# CORS_ORIGIN=

# Max managed containers (0 = unlimited).
CONTAINER_LIMIT=0

# Managed container label. Use distinct MANAGED_LABEL_VALUE per Deployer instance on same host.
MANAGED_LABEL=managed-by
MANAGED_LABEL_VALUE=deployer

# Private registry for image pull via API.
# REGISTRY_HOST=registry.example.com
# REGISTRY_USER=registry_user
# REGISTRY_PASSWORD=change-me

# Multi-registry (preferred): JSON array of {host,user,password}.
# REGISTRY_CREDENTIALS_JSON=[{"host":"registry.example.com","user":"u","password":"p"}]

# API key for scripts / external services (header: x-api-key).
# API_KEY=change-me

# Deploy/operations auth mode:
# dual - UI session and x-api-key (default)
# api  - x-api-key only (if API_KEY set)
# ui   - session only
# DEPLOYER_AUTH_MODE=dual

# Async operations: POST → 202 + operationId, poll GET /api/operations/:id
# MAX_CONCURRENT_OPERATIONS=10
# MAX_QUEUED_OPERATIONS=100
# OPERATION_TTL_HOURS=24
# DEPLOYER_SYNC_LEGACY=0

# MCP keys (HTTP /mcp): {DEPLOY_BASE_PATH}/.deployer-state/mcp-keys.json — issue/revoke in UI.
# DEPLOYER_MCP_TOOLS_DENY=deployer_container_delete,deployer_template_delete
