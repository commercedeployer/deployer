{
  "id": "docker-demo-basic",
  "name": "Docker Demo — Basic",
  "description": "Demo docker/getting-started, basic tier. Storefront: saas_instance / docker-demo-basic (72h trial in Commerce). Same demo-data volume as free/pro.",
  "image": "docker/getting-started",
  "fields": [
    {
      "key": "HOST_PORT",
      "label": "Host port",
      "required": true,
      "default": "8082"
    }
  ],
  "env": [
    { "name": "DEMO_PLAN", "value": "basic" },
    { "name": "DEMO_MAX_USERS", "value": "10" }
  ],
  "labels": [
    { "name": "demo.plan", "value": "basic" }
  ],
  "volumes": [
    { "host": "{{DEPLOY_BASE_PATH}}/{{CONTAINER_NAME}}/demo-data", "container": "/tmp/demo-data" }
  ],
  "networks": [],
  "ports": [
    { "containerPort": 80, "hostPort": "{{HOST_PORT}}", "protocol": "tcp" }
  ]
}
