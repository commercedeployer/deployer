# Optional tools installed inside the Deployer container on start (provision/deprovision).
# node is always present (base image) — not listed here.
#
# Comma or semicolon list; empty = bash,curl
# DEPLOYER_SOFTWARE=bash,curl,psql,jq
#
# Keys -> Alpine packages:
#   bash, psql (postgresql-client), mysql/mariadb (mariadb-client), mongosh,
#   curl, jq, python3, openssl, rsync, openssh, bind, zip

DEPLOYER_SOFTWARE=bash,curl
