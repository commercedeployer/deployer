{
  "name": "deployer",
  "version": "1.2.0",
  "description": "Deployer — deploy containers from JSON templates",
  "main": "server/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/commercedeployer/deployer.git"
  },
  "bugs": {
    "url": "https://github.com/commercedeployer/deployer/issues"
  },
  "homepage": "https://github.com/commercedeployer/deployer#readme",
  "keywords": [
    "docker",
    "deploy",
    "templates",
    "traefik",
    "containers"
  ],
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node scripts/run-unit-tests.js",
    "test:ui": "node scripts/ui-smoke-playwright.js",
    "test:ui:e2e": "node scripts/ui-e2e-playwright.js",
    "test:ui:deploy": "node scripts/ui-deploy-smoke-playwright.js",
    "test:integration": "node scripts/run-integration-tests.js",
    "test:all": "node scripts/run-unit-tests.js && node scripts/run-integration-tests.js && node scripts/ui-smoke-playwright.js && node scripts/ui-e2e-playwright.js && node scripts/ui-deploy-smoke-playwright.js",
    "restore-templates": "node scripts/restore-templates.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.52.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "swagger-ui-express": "^5.0.0"
  }
}
