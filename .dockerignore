# Контекст сборки Docker: не копировать в образ лишнее (меньше размер, нет секретов из .env).

.git
.github

node_modules
npm-debug.log*
*.log

.env
.env.*
!.env.example

# Тесты и артефакты не нужны внутри образа
test
test-artifacts-e2e
test-artifacts-*

# Templates/ — рабочая производная папка (mount-дериватив),
# реальный seed берётся из templates-bundled внутри образа.
templates/

# Корневые *.md (документация репозитория)
/*.md

# IDE и Cursor
.cursor
.cursorignore
cursor.ignore
.vscode
.idea

# Прочее
.DS_Store
Thumbs.db
coverage
.nyc_output
